<!DOCTYPE html>
<html lang="th">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0">
<title>Fleggfoods</title>
<link href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@700;900&family=Lato:wght@400;700;900&family=IBM+Plex+Mono:wght@600;700&display=swap" rel="stylesheet">
<style>
*{box-sizing:border-box;margin:0;padding:0;-webkit-tap-highlight-color:transparent}
body{font-family:'Lato',sans-serif;min-height:100vh;background:#1a0a00;color:#f5e6c8;font-size:19px}

/* ── PAGE VISIBILITY ─────────────────── */
.page{display:none}
.page.active{display:block}
#pg-home.active{display:flex}
#pg-pin.active{display:flex}

/* ── HOME ──────────────────────────────── */
#pg-home{flex-direction:column;align-items:center;justify-content:center;min-height:100vh;
  background:radial-gradient(ellipse at 50% 0%,#3a1000 0%,#0d0500 55%,#000 100%);
  padding:40px 24px;text-align:center}
.home-icon{font-size:5rem;margin-bottom:16px;animation:float 3s ease-in-out infinite}
@keyframes float{0%,100%{transform:translateY(0)}50%{transform:translateY(-14px)}}
.home-logo{font-family:'Playfair Display',serif;font-size:3rem;font-weight:900;color:#f0a830;letter-spacing:4px;margin-bottom:6px}
.home-tagline{color:#8a6040;font-size:.9rem;letter-spacing:2px;text-transform:uppercase;margin-bottom:52px}
.home-btns{display:flex;flex-direction:column;gap:14px;width:100%;max-width:320px}
.hbtn{width:100%;padding:20px;border:none;border-radius:16px;font-size:1.1rem;font-weight:700;cursor:pointer;transition:transform .12s,box-shadow .12s;letter-spacing:.5px;font-family:'Lato',sans-serif}
.hbtn:active{transform:scale(.97)}
.hbtn-order{background:linear-gradient(135deg,#c8801a,#f0a830);color:#000;box-shadow:0 6px 24px rgba(200,128,26,.45)}
.hbtn-stock{background:linear-gradient(135deg,#1a6b3a,#2ecc71);color:#000;box-shadow:0 6px 24px rgba(46,204,113,.35)}
.hbtn-kitchen{background:#181b24;color:#e8eaf0;border:1px solid #252a38}
.hbtn-admin{background:transparent;color:#5a6275;border:2px solid #252a38;font-size:.95rem}

/* ── PIN ──────────────────────────────── */
#pg-pin{flex-direction:column;align-items:center;justify-content:center;min-height:100vh;
  background:#0d0500;padding:24px;text-align:center}
.pin-icon{font-size:2.5rem;margin-bottom:12px}
.pin-title{font-family:'Playfair Display',serif;font-size:1.5rem;color:#f0a830;margin-bottom:4px}
.pin-sub{color:#8a6040;font-size:.88rem;margin-bottom:28px}
.pin-dots{display:flex;gap:14px;justify-content:center;margin-bottom:28px}
.pin-dot{width:18px;height:18px;border-radius:50%;background:#3a1a00;border:2px solid #8a6040;transition:all .2s}
.pin-dot.filled{background:#f0a830;border-color:#f0a830;box-shadow:0 0 10px rgba(240,168,48,.5)}
.pin-dot.error{background:#e74c3c;border-color:#e74c3c;animation:shake .35s ease}
@keyframes shake{0%,100%{transform:translateX(0)}25%{transform:translateX(-7px)}75%{transform:translateX(7px)}}
.pin-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:11px;max-width:260px;width:100%}
.pbtn{padding:19px;background:#181b24;border:1px solid #252a38;border-radius:13px;
  font-size:1.45rem;font-weight:700;color:#e8eaf0;cursor:pointer;transition:all .14s;
  font-family:'IBM Plex Mono',monospace}
.pbtn:active{background:#252a38;transform:scale(.94)}
.pbtn.del{font-size:1rem;color:#5a6275}
.pin-back{margin-top:22px;background:transparent;border:none;color:#5a6275;font-size:.88rem;cursor:pointer;padding:10px;font-family:'Lato',sans-serif}
.pin-err-msg{color:#e74c3c;font-size:.85rem;margin-top:12px;height:20px}

/* ── SHARED HEADER ────────────────────── */
.app-bar{background:#0d0500;border-bottom:3px solid #c8801a;padding:14px 20px;
  display:flex;align-items:center;justify-content:space-between;
  position:sticky;top:0;z-index:100}
.app-bar-logo{font-family:'Playfair Display',serif;font-size:1.55rem;font-weight:900;color:#f0a830}
.bar-right{display:flex;align-items:center;gap:10px}
.back-btn{background:rgba(200,128,26,.15);border:1px solid rgba(200,128,26,.35);
  color:#c8801a;padding:8px 16px;border-radius:8px;font-size:.82rem;font-weight:700;cursor:pointer;font-family:'Lato',sans-serif}
.cart-pill{background:#c8801a;color:#000;border-radius:99px;padding:8px 17px;font-size:.9rem;font-weight:900}

/* ── ORDER – NAME BAR ─────────────────── */
.name-bar{background:linear-gradient(135deg,#2a1000,#1a0800);border-bottom:3px solid #f0a830;padding:18px 20px}
.name-lbl{font-size:.8rem;color:#f0a830;text-transform:uppercase;letter-spacing:2px;font-weight:900;margin-bottom:9px}
.name-wrap{position:relative}
.name-ico{position:absolute;left:15px;top:50%;transform:translateY(-50%);font-size:1.4rem;pointer-events:none}
.name-inp{width:100%;background:#0d0500;border:3px solid #c8801a;color:#f5e6c8;
  border-radius:12px;padding:18px 18px 18px 52px;font-size:1.2rem;font-weight:700;
  outline:none;transition:border-color .2s,box-shadow .2s;font-family:'Lato',sans-serif}
.name-inp::placeholder{color:#5a3a10;font-weight:400}
.name-inp:focus{border-color:#f0a830;box-shadow:0 0 0 4px rgba(240,168,48,.2)}
.name-inp.err{border-color:#e74c3c;box-shadow:0 0 0 4px rgba(231,76,60,.25);animation:shake .35s ease}

.fries-bar{background:#c0392b;color:#fff;text-align:center;padding:10px;font-weight:900;font-size:.88rem;letter-spacing:1.5px}

/* ── TABS ────────────────────────────── */
.tabs{display:flex;background:#0d0500;border-bottom:2px solid #3a1a00}
.tab-btn{flex:1;padding:16px 6px;text-align:center;cursor:pointer;font-size:1rem;font-weight:700;
  color:#8a6040;border-bottom:3px solid transparent;transition:all .2s;user-select:none}
.tab-btn.on{color:#f0a830;border-bottom-color:#f0a830;background:#1a0a00}

/* ── MENU GRID ──────────────────────── */
.mgrid{display:grid;grid-template-columns:repeat(auto-fill,minmax(300px,1fr));gap:15px;padding:18px;max-width:1100px;margin:0 auto}
.mgrid.off{display:none!important}
.mcard{background:#0d0500;border:2px solid #3a1a00;border-radius:14px;padding:19px;display:flex;flex-direction:column;gap:10px;transition:border-color .2s}
.mcard:hover{border-color:#c8801a}
.mcard.sold{opacity:.4;pointer-events:none}
.card-emo{font-size:2.8rem;line-height:1}
.card-tag{background:#3a1a00;color:#f0a830;font-size:.8rem;letter-spacing:1.5px;text-transform:uppercase;
  padding:4px 12px;border-radius:99px;display:inline-block;width:fit-content;font-weight:700}
.card-tag.bs{background:#d4a017;color:#000;}
.card-name{font-family:'Playfair Display',serif;font-size:1.35rem;color:#f5e6c8;font-weight:700}
.card-desc{font-size:.95rem;color:#8a6040;line-height:1.6}
.card-name-th{font-size:.92rem;color:#c8a060;margin-top:2px;font-weight:400}
.sold-lbl{font-size:.88rem;color:#e74c3c;font-weight:700}
.card-foot{display:flex;align-items:center;justify-content:space-between;margin-top:6px;gap:10px}
.card-price{font-family:'Playfair Display',serif;font-size:1.55rem;color:#f0a830;font-weight:700;flex-shrink:0}
.add-btn{background:#c8801a;border:none;color:#fff;padding:13px 24px;border-radius:99px;
  font-size:1rem;font-weight:700;cursor:pointer;flex-shrink:0;font-family:'Lato',sans-serif}
.add-btn:active{background:#f0a830}
.qty-ctrl{display:flex;align-items:center;gap:12px;flex-shrink:0}
.qty-btn{background:#3a1a00;border:none;color:#f5e6c8;width:42px;height:42px;border-radius:50%;
  font-size:1.4rem;cursor:pointer;display:flex;align-items:center;justify-content:center;font-family:'Lato',sans-serif}
.qty-btn:active{background:#c8801a}
.qty-n{font-size:1.2rem;font-weight:700;min-width:22px;text-align:center}

/* ── DONENESS ────────────────────────── */
.doneness-wrap{margin-top:4px}
.doneness-lbl{font-size:.78rem;color:#8a6040;text-transform:uppercase;letter-spacing:1px;font-weight:700;margin-bottom:7px}
.doneness-opts{display:flex;gap:6px;flex-wrap:wrap}
.d-opt{padding:8px 14px;border-radius:99px;border:2px solid #3a1a00;background:#0d0500;
  color:#8a6040;font-size:.85rem;font-weight:700;cursor:pointer;transition:all .18s;font-family:'Lato',sans-serif;white-space:nowrap}
.d-opt:active{transform:scale(.95)}
.d-opt.sel{color:#000;border-color:transparent}
.d-opt[data-d="rare"].sel{background:#c0392b;color:#fff}
.d-opt[data-d="medium-rare"].sel{background:#e05c2a;color:#fff}
.d-opt[data-d="medium"].sel{background:#d4821a;color:#fff}
.d-opt[data-d="medium-well"].sel{background:#a06020;color:#fff}
.d-opt[data-d="well-done"].sel{background:#6b4226;color:#fff}
.doneness-req{font-size:.75rem;color:#e74c3c;margin-top:5px;display:none}
.doneness-req.show{display:block}
.cart-box{max-width:680px;margin:0 auto;padding:0 20px 40px}
.cart-ttl{font-family:'Playfair Display',serif;font-size:1.55rem;color:#f0a830;
  border-bottom:2px solid #3a1a00;padding:24px 0 11px;margin-bottom:0}
.cart-row{display:flex;align-items:center;gap:12px;padding:12px 0;border-bottom:1px solid #3a1a00}
.cart-name{flex:1;font-size:.93rem}
.cart-sub{color:#8a6040;font-size:.85rem}
.cart-price{color:#f0a830;font-family:'Playfair Display',serif;font-size:1rem}
.cart-total-row{display:flex;justify-content:space-between;align-items:center;padding:17px 0 10px}
.cart-total-lbl{font-size:.9rem;color:#8a6040;text-transform:uppercase;letter-spacing:1px}
.cart-total-amt{font-family:'Playfair Display',serif;font-size:2rem;color:#f0a830;font-weight:700}
.note-inp{width:100%;background:#0d0500;border:2px solid #3a1a00;color:#f5e6c8;
  border-radius:10px;padding:12px 15px;font-family:'Lato',sans-serif;font-size:.93rem;
  outline:none;resize:none;transition:border-color .2s}
.note-inp:focus{border-color:#c8801a}
.send-btn{width:100%;padding:22px;background:#c8801a;border:none;border-radius:12px;
  color:#fff;font-family:'Playfair Display',serif;font-size:1.35rem;font-weight:700;
  cursor:pointer;margin-top:15px;letter-spacing:1px;font-style:normal}
.send-btn:active{background:#f0a830}
.send-btn:disabled{background:#5a3a10;color:#888;cursor:not-allowed}

/* ── WAITING / READY ─────────────────── */
.wait-box{display:none;text-align:center;padding:50px 20px}
.wait-spin{width:44px;height:44px;border:4px solid #3a1a00;border-top-color:#f0a830;
  border-radius:50%;animation:spin 1s linear infinite;margin:0 auto 18px}
@keyframes spin{to{transform:rotate(360deg)}}
.wait-title{font-family:'Playfair Display',serif;font-size:1.5rem;margin-bottom:8px}
.wait-id{font-family:'Playfair Display',serif;font-size:3.5rem;color:#f0a830;font-weight:900;margin:10px 0}
.wait-sub{color:#8a6040;font-size:.92rem;margin-bottom:24px}
.steps{display:flex;align-items:center;justify-content:center;margin:28px auto;max-width:380px}
.step{display:flex;flex-direction:column;align-items:center;gap:8px;flex:1}
.step-c{width:52px;height:52px;border-radius:50%;border:2px solid #3a1a00;background:#0d0500;
  display:flex;align-items:center;justify-content:center;font-size:1.35rem;transition:all .5s}
.step-c.on{border-color:#f0a830;background:#3a1a00;box-shadow:0 0 16px rgba(240,168,48,.35)}
.step-c.done{border-color:#2ecc71;background:#0d2a1a}
.step-l{font-size:.76rem;color:#8a6040;text-align:center}
.step-l.on{color:#f0a830;font-weight:700}
.step-l.done{color:#2ecc71;font-weight:700}
.step-line{height:2px;flex:1;background:#3a1a00;margin-top:-20px;transition:background .5s}
.step-line.done{background:#2ecc71}

.ready-box{display:none;text-align:center;padding:50px 20px;animation:popin .5s ease}
@keyframes popin{0%{transform:scale(.8);opacity:0}60%{transform:scale(1.05)}100%{transform:scale(1);opacity:1}}
.ready-ico{font-size:6rem;animation:bob .6s ease infinite alternate}
@keyframes bob{from{transform:translateY(0)}to{transform:translateY(-12px)}}
.ready-title{font-family:'Playfair Display',serif;font-size:2.2rem;color:#2ecc71;margin:14px 0 10px}
.ready-sub{color:#8a6040;font-size:.98rem;line-height:2;margin-bottom:22px}
.ready-id{font-family:'Playfair Display',serif;font-size:2.4rem;color:#f0a830}
.again-btn{background:transparent;border:3px solid #c8801a;color:#c8801a;padding:12px 30px;
  border-radius:99px;font-size:.98rem;font-weight:700;cursor:pointer;margin-top:20px;font-family:'Lato',sans-serif}
.again-btn:active{background:#c8801a;color:#fff}

.sumbox{background:#0d0500;border:1px solid #3a1a00;border-radius:12px;padding:15px;margin:15px auto;max-width:340px;text-align:left}
.sumrow{display:flex;gap:10px;padding:7px 0;font-size:.88rem;border-bottom:1px solid #3a1a00}
.sumrow:last-child{border-bottom:none}

/* ── KITCHEN ─────────────────────────── */
#pg-kitchen{background:#0f1117;min-height:100vh;color:#e8eaf0}
.k-bar{background:#181b24;border-bottom:1px solid #252a38;padding:12px 18px;
  display:flex;align-items:center;justify-content:space-between;position:sticky;top:0;z-index:100}
.k-logo{font-family:'IBM Plex Mono',monospace;font-size:.95rem;font-weight:700;color:#f5a623;letter-spacing:3px}
.k-right{display:flex;align-items:center;gap:10px}
.k-clock{font-family:'IBM Plex Mono',monospace;font-size:1.2rem;font-weight:600;letter-spacing:2px}
.live-wrap{display:flex;align-items:center;gap:5px}
.ldot{width:8px;height:8px;border-radius:50%;background:#2ecc71;box-shadow:0 0 7px #2ecc71;animation:pulse 2s infinite}
.ldot.off{background:#e74c3c;box-shadow:0 0 7px #e74c3c}
@keyframes pulse{0%,100%{opacity:1}50%{opacity:.3}}
.live-lbl{font-size:.7rem;color:#2ecc71;text-transform:uppercase;letter-spacing:1px;font-family:'IBM Plex Mono',monospace}
.live-lbl.off{color:#e74c3c}
.audio-btn{background:rgba(245,166,35,.15);border:1px solid rgba(245,166,35,.3);
  color:#f5a623;padding:6px 12px;border-radius:8px;font-size:.76rem;cursor:pointer;font-family:'Lato',sans-serif}
.audio-btn.on{background:rgba(46,204,113,.15);border-color:rgba(46,204,113,.3);color:#2ecc71;cursor:default}
.k-stats{display:flex;gap:1px;background:#252a38;border-bottom:1px solid #252a38}
.k-stat{flex:1;background:#181b24;padding:11px 14px}
.k-stat-n{font-family:'IBM Plex Mono',monospace;font-size:1.5rem;font-weight:700}
.k-stat-l{font-size:.65rem;color:#5a6275;text-transform:uppercase;letter-spacing:1px;margin-top:3px}
.board{display:grid;grid-template-columns:repeat(3,1fr);gap:0}
@media(max-width:700px){.board{grid-template-columns:1fr}}
.kcol{border-right:1px solid #252a38;min-height:400px}
.kcol:last-child{border-right:none}
.kcol-hd{padding:12px 14px;display:flex;align-items:center;justify-content:space-between;
  border-bottom:2px solid #252a38;background:#181b24}
.kcol-title{font-family:'IBM Plex Mono',monospace;font-size:.73rem;font-weight:700;letter-spacing:2px;text-transform:uppercase}
.ct-new{color:#f5a623}.ct-cooking{color:#3498db}.ct-done{color:#2ecc71}
.kcol-cnt{font-family:'IBM Plex Mono',monospace;font-size:.7rem;background:#252a38;color:#5a6275;padding:2px 9px;border-radius:99px}
.kcol-body{padding:10px;display:flex;flex-direction:column;gap:8px}
.kcard{background:#181b24;border:1px solid #252a38;border-radius:10px;padding:12px;animation:slidein .3s ease}
@keyframes slidein{from{opacity:0;transform:translateY(-8px)}to{opacity:1;transform:translateY(0)}}
.kcard.urg{border-color:#e74c3c}
.kcard-top{display:flex;justify-content:space-between;align-items:flex-start;margin-bottom:8px}
.kcard-id{font-family:'IBM Plex Mono',monospace;font-size:.98rem;font-weight:700;color:#f5a623}
.kcard-table{font-size:.7rem;color:#5a6275;margin-top:2px}
.ktimer{font-family:'IBM Plex Mono',monospace;font-size:.88rem;font-weight:700;text-align:right;padding:3px 8px;border-radius:6px}
.ktimer.t-green{color:#2ecc71;background:rgba(46,204,113,.12)}
.ktimer.t-yellow{color:#f1c40f;background:rgba(241,196,15,.12)}
.ktimer.t-red{color:#e74c3c;background:rgba(231,76,60,.15);animation:pulse-red 1s ease-in-out infinite}
@keyframes pulse-red{0%,100%{opacity:1}50%{opacity:.6}}
.urg-tag{background:#e74c3c;color:#fff;font-size:.6rem;padding:2px 7px;border-radius:99px;font-weight:700;margin-top:3px;display:inline-block}
.kitems{display:flex;flex-direction:column;gap:5px;margin-bottom:9px}
.kitem{display:flex;align-items:flex-start;gap:7px;background:#0f1117;border-radius:6px;padding:7px 9px}
.kitem-emo{font-size:.95rem;flex-shrink:0}
.kitem-name{font-size:.8rem;font-weight:600;flex:1}
.kitem-note{font-size:.68rem;color:#e05c2a;margin-top:2px}
.kitem-qty{font-family:'IBM Plex Mono',monospace;font-size:.72rem;background:#252a38;color:#f5a623;padding:2px 7px;border-radius:99px;font-weight:700;flex-shrink:0}
.kactions{display:flex;gap:6px}
.kbtn{flex:1;padding:8px;border:none;border-radius:7px;font-size:.76rem;font-weight:700;cursor:pointer;transition:all .15s;font-family:'Lato',sans-serif}
.kbtn-start{background:rgba(52,152,219,.15);color:#3498db;border:1px solid rgba(52,152,219,.3)}
.kbtn-start:hover{background:#3498db;color:#fff}
.kbtn-done{background:rgba(46,204,113,.15);color:#2ecc71;border:1px solid rgba(46,204,113,.3)}
.kbtn-done:hover{background:#2ecc71;color:#fff}
.kbtn-cancel{background:rgba(231,76,60,.1);color:#e74c3c;border:1px solid rgba(231,76,60,.2);flex:0;padding:8px 10px}
.kbtn-cancel:hover{background:#e74c3c;color:#fff}
.kbtn-clear{background:rgba(90,98,117,.2);color:#5a6275;border:1px solid #252a38}
.ktotal{font-family:'IBM Plex Mono',monospace;font-size:.75rem;color:#5a6275;text-align:right;margin-top:6px}
.ktotal span{color:#f5a623;font-weight:700}
.kempty{text-align:center;padding:30px 15px;color:#5a6275;font-size:.8rem;line-height:2;opacity:.6}
.k-toast{position:fixed;bottom:24px;left:50%;transform:translateX(-50%) translateY(20px);
  background:#2ecc71;color:#000;padding:10px 22px;border-radius:99px;font-weight:700;
  font-size:.86rem;opacity:0;transition:all .35s;z-index:999;pointer-events:none;white-space:nowrap}
.k-toast.show{opacity:1;transform:translateX(-50%) translateY(0)}
.k-clear-btn{display:block;margin:16px auto 24px;background:#181b24;color:#5a6275;border:1px solid #252a38;
  border-radius:99px;padding:9px 20px;font-size:.78rem;cursor:pointer;font-family:'Lato',sans-serif}
.k-clear-btn:hover{background:#e74c3c;color:#fff;border-color:#e74c3c}

/* ── ADMIN ───────────────────────────── */
#pg-admin{background:#0f1117;min-height:100vh;color:#e8eaf0}
.a-bar{background:#181b24;border-bottom:2px solid #f5a623;padding:13px 20px;
  display:flex;align-items:center;justify-content:space-between;position:sticky;top:0;z-index:100}
.a-logo{font-family:'IBM Plex Mono',monospace;font-size:.95rem;font-weight:700;color:#f5a623;letter-spacing:3px}
.a-badge{background:#e05c2a;color:#fff;font-size:.66rem;padding:3px 10px;border-radius:99px;font-weight:700;letter-spacing:1px}
.sync-lbl{font-size:.68rem;font-family:'IBM Plex Mono',monospace;color:#2ecc71}
.a-layout{display:grid;grid-template-columns:1fr 350px;min-height:calc(100vh - 55px)}
@media(max-width:800px){.a-layout{grid-template-columns:1fr}}
.a-left{padding:18px;border-right:1px solid #252a38;overflow-y:auto}
.a-right{padding:20px;background:#181b24;overflow-y:auto}
@media(max-width:800px){.a-right{display:none}}
.a-stats{display:flex;gap:9px;margin-bottom:18px}
.a-stat{flex:1;background:#0f1117;border:1px solid #252a38;border-radius:10px;padding:10px 12px}
.a-stat-n{font-family:'IBM Plex Mono',monospace;font-size:1.3rem;font-weight:700}
.a-stat-l{font-size:.64rem;color:#5a6275;text-transform:uppercase;letter-spacing:1px;margin-top:2px}
.ctabs{display:flex;gap:7px;margin-bottom:16px}
.ctab{padding:7px 14px;border-radius:8px;font-size:.78rem;font-weight:600;cursor:pointer;border:1px solid #252a38;color:#5a6275;transition:all .2s}
.ctab.on{background:rgba(245,166,35,.15);border-color:#f5a623;color:#f5a623}
.a-sec-hd{display:flex;align-items:center;justify-content:space-between;margin-bottom:12px}
