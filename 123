};

/* ═══════════════════════════════════
   STOCK ORDER
═══════════════════════════════════ */
const STOCK = {
  cart:{}, menu:null, stock:{}, lastOrder:null,

  async init(){
    this.cart={};
    this.menu=JSON.parse(JSON.stringify(DEFAULT_MENU));
    G('st-main').style.display='block';
    G('st-done-box').style.display='none';
    G('st-name-inp').value='';
    this.updatePill();
    // Load menu + stock from Firebase
    const [m,s]=await Promise.all([fbGet('/menu'),fbGet('/stock')]);
    if(m&&Object.keys(m).length>0)this.menu=m;
    this.stock=s||{};
    this.render();
  },

  tab(cat,el){
    document.querySelectorAll('#pg-stock .st-tab').forEach(t=>t.classList.remove('on'));
    el.classList.add('on');
    ['burger','steak','drinks'].forEach(c=>G('st-grid-'+c).classList.toggle('off',c!==cat));
  },

  getStock(id){
    const v=this.stock[id];
    if(v===undefined||v===null)return -1; // unlimited
    return parseInt(v);
  },

  render(){
    ['burger','steak','drinks'].forEach(cat=>{
      const el=G('st-grid-'+cat);if(!el)return;
      const items=(this.menu[cat]||[]);
      if(!items.length){el.innerHTML='<p style="padding:20px;color:#2a5c35">ไม่มีเมนู</p>';return;}
      el.innerHTML=items.map(item=>{
        const stk=this.getStock(item.id);
        const isOut=stk===0;
        const isLow=stk>0&&stk<=3;
        const isUnlim=stk<0;
        const qty=(this.cart[item.id]||{}).qty||0;
        const stkLabel=isUnlim?'∞ ไม่จำกัด':isOut?'หมดสต๊อก':`เหลือ ${stk-qty} ชิ้น`;
        const stkClass=isOut?'out':isLow?'low':'ok';
        const imgH=item.image?`<img src="${item.image}" alt="${item.name}" style="width:100%;height:130px;object-fit:cover;border-radius:9px;">`:`<div style="font-size:2.5rem;line-height:1">${item.emoji||'🍔'}</div>`;
        const thSub=item.nameTh?`<div class="stcard-th">${item.nameTh}</div>`:'';
        let ctrl='';
        const canAdd=!isOut&&(isUnlim||(stk-qty>0));
        if(canAdd)ctrl=qty===0?`<button class="st-add-btn" onclick="STOCK.add('${item.id}')">+ เพิ่ม</button>`:`<div class="st-qty-ctrl"><button class="st-qty-btn" onclick="STOCK.remove('${item.id}')">−</button><span class="st-qty-n">${qty}</span><button class="st-qty-btn" onclick="STOCK.add('${item.id}')">+</button></div>`;
        return `<div class="stcard${isOut?' out':isLow?' low':''}">
          <div class="stk-badge ${stkClass}">${stkLabel}</div>
          ${imgH}
          <div class="stcard-name">${item.name}</div>${thSub}
          <div class="stcard-desc">${item.desc}</div>
          <div class="stcard-foot"><div class="stcard-price">฿${item.price}</div>${ctrl}</div>
        </div>`;
      }).join('');
    });
    this.updateCart();
  },

  add(id){
    const item=this.findItem(id);if(!item)return;
    const stk=this.getStock(id);
    const qty=(this.cart[id]||{}).qty||0;
    if(stk>=0&&qty>=stk){return;} // out of stock
    if(!this.cart[id])this.cart[id]={...item,qty:0};
    this.cart[id].qty++;
    this.render();
  },

  remove(id){
    if(!this.cart[id])return;
    this.cart[id].qty--;
    if(this.cart[id].qty<=0)delete this.cart[id];
    this.render();
  },

  findItem(id){
    for(const arr of Object.values(this.menu)){
      const f=arr.find(i=>String(i.id)===String(id));
      if(f)return f;
    }return null;
  },

  updatePill(){
    const items=Object.values(this.cart);
    const qty=items.reduce((s,i)=>s+i.qty,0);
    const total=items.reduce((s,i)=>s+i.price*i.qty,0);
    G('st-pill').textContent=`🛒 ${qty} · ฿${total.toLocaleString()}`;
  },

  updateCart(){
    this.updatePill();
    const items=Object.values(this.cart);
    const box=G('st-cart-box');
    if(!items.length){box.style.display='none';return;}
    box.style.display='block';
    const total=items.reduce((s,i)=>s+i.price*i.qty,0);
    G('st-cart-rows').innerHTML=items.map(i=>`
      <div class="st-cart-row">
        <span style="font-size:1.2rem">${i.emoji||'🍔'}</span>
        <span class="st-cart-name">${i.name}</span>
        <span class="st-cart-sub">x${i.qty}</span>
        <span class="st-cart-price">฿${(i.price*i.qty).toLocaleString()}</span>
      </div>`).join('');
    G('st-total').textContent=`฿${total.toLocaleString()}`;
  },

  async confirm(){
    const name=G('st-name-inp').value.trim();
    if(!name){
      const inp=G('st-name-inp');
      inp.classList.add('err');
      inp.placeholder='⚠ กรุณาใส่ชื่อก่อน · Please enter your name!';
      inp.focus();
      setTimeout(()=>{inp.classList.remove('err');inp.placeholder='กรอกชื่อก่อนสั่ง · Enter your name first...';},3000);
      return;
    }
    const items=Object.values(this.cart);
    if(!items.length){alert('กรุณาเลือกเมนูอย่างน้อย 1 รายการ');return;}
    const btn=G('st-confirm-btn');btn.disabled=true;btn.textContent='⏳ กำลังบันทึก...';
    // Deduct stock in Firebase
    const updates={};
    for(const i of items){
      const stk=this.getStock(i.id);
      if(stk>=0){
        const newStk=Math.max(0,stk-i.qty);
        updates[i.id]=newStk;
        this.stock[i.id]=newStk;
      }
    }
    if(Object.keys(updates).length>0)await fbPatch('/stock',updates);
    // Save order log
    const oid=Date.now();
    const total=items.reduce((s,i)=>s+i.price*i.qty,0);
    await fbSet(`/stock_orders/${oid}`,{id:oid,name,items:items.map(i=>({id:i.id,name:i.name,emoji:i.emoji||'🍔',price:i.price,qty:i.qty})),total,createdAt:oid});
    this.lastOrder={name,items:[...items],total,oid};
    // Show done
    const sumHtml=items.map(i=>`<div class="sumrow" style="border-color:#1a3a20"><span>${i.emoji||'🍔'}</span><span style="flex:1;color:#e8f5e9">${i.name}</span><span style="color:#2a5c35">x${i.qty}</span><span style="color:#2ecc71">฿${(i.price*i.qty).toLocaleString()}</span></div>`).join('');
    G('st-done-sub').textContent=`สั่งโดย: ${name}`;
    G('st-done-sum').innerHTML=sumHtml+`<div style="display:flex;justify-content:space-between;padding-top:12px;margin-top:8px;border-top:2px solid #2ecc71"><span style="color:#2a5c35;font-size:.85rem">ยอดรวม / Total</span><span style="color:#2ecc71;font-family:'Playfair Display',serif;font-size:1.5rem;font-weight:700">฿${total.toLocaleString()}</span></div>`;
    G('st-main').style.display='none';
    G('st-done-box').style.display='block';
    btn.disabled=false;btn.textContent='✅ ยืนยันสั่ง & หักสต๊อก';
  },

  print(){
    if(!this.lastOrder&&!Object.values(this.cart).length)return;
    const src=this.lastOrder||{name:G('st-name-inp').value||'—',items:Object.values(this.cart),total:Object.values(this.cart).reduce((s,i)=>s+i.price*i.qty,0),oid:Date.now()};
    const rows=src.items.map(i=>`<tr><td>${i.emoji||'🍔'} ${i.name}</td><td style="text-align:center">x${i.qty}</td><td style="text-align:right">฿${(i.price*i.qty).toLocaleString()}</td></tr>`).join('');
    const now=new Date().toLocaleString('th-TH');
    G('print-area').style.display='block';
    G('print-area').innerHTML=`
      <div style="max-width:400px;margin:0 auto;font-family:sans-serif">
        <div style="text-align:center;margin-bottom:16px">
          <div style="font-size:2rem;font-weight:900;letter-spacing:3px">FLEGG FOODS</div>
          <div style="font-size:.9rem;color:#666">📦 Stock Order Receipt</div>
          <div style="font-size:.8rem;color:#999;margin-top:4px">${now}</div>
        </div>
        <div style="border-top:2px solid #000;border-bottom:1px dashed #999;padding:8px 0;margin-bottom:8px">
          <b>ชื่อผู้สั่ง / Name:</b> ${src.name}
        </div>
        <table style="width:100%;border-collapse:collapse;font-size:.9rem">
          <thead><tr style="border-bottom:1px solid #999"><th style="text-align:left">รายการ</th><th>จำนวน</th><th style="text-align:right">ราคา</th></tr></thead>
          <tbody>${rows}</tbody>
        </table>
        <div style="border-top:2px solid #000;margin-top:12px;padding-top:10px;display:flex;justify-content:space-between;font-size:1.1rem;font-weight:700">
          <span>ยอดรวม / Total</span><span>฿${src.total.toLocaleString()}</span>
        </div>
        <div style="text-align:center;margin-top:20px;font-size:.75rem;color:#999">ขอบคุณที่ใช้บริการ · Thank you!</div>
      </div>`;
    window.print();
    setTimeout(()=>{G('print-area').style.display='none';},1000);
  },

  reset(){
    this.cart={};this.lastOrder=null;
    G('st-main').style.display='block';
    G('st-done-box').style.display='none';
    G('st-name-inp').value='';
    this.render();
  }
};

