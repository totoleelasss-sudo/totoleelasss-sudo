/* ═══════════════════════════════════
   QUICK ORDER
═══════════════════════════════════ */
const QUICK = {
  cart:{}, menu:null,

  async init(){
    this.cart={};
    this.menu=JSON.parse(JSON.stringify(DEFAULT_MENU));
    fbGet('/menu').then(m=>{
      if(m&&Object.keys(m).length>0){this.menu=m;}
      this.render();
    }).catch(()=>this.render());
    this.render();
  },

  render(){
    // Sections: Burgers + Steak only (no drinks)
    const SECTIONS=[
      {key:'burger', label:'🍔 Burgers'},
      {key:'steak',  label:'🥩 Steak'},
    ];
    const DONENESS_OPTS=[
      {key:'rare',        short:'Rare'},
      {key:'medium-rare', short:'Med Rare'},
      {key:'medium',      short:'Medium'},
      {key:'medium-well', short:'Med Well'},
      {key:'well-done',   short:'Well Done'},
    ];
    let html='';
    SECTIONS.forEach(sec=>{
      const items=(this.menu[sec.key]||[]).filter(i=>i.available!==false);
      if(!items.length)return;
      html+=`<div class="qk-sec"><div class="qk-sec-title">${sec.label}</div><table class="qk-table">`;
      items.forEach(item=>{
        const qty=(this.cart[item.id]||{}).qty||0;
        const selDone=(this.cart[item.id]||{}).doneness||'';
        // doneness row inside table (spans all cols)
        let doneRow='';
        if(item.doneness){
          const opts=DONENESS_OPTS.map(d=>`<button class="qk-done-opt${selDone===d.key?' qk-done-sel':''}" onclick="QUICK.setDone('${item.id}','${d.key}')">${d.short}</button>`).join('');
          const warn=qty>0&&!selDone?'<span style="color:#e74c3c;font-size:.7rem;margin-left:6px">⚠ เลือกความสุกด้วย</span>':'';
          doneRow=`<tr><td colspan="4" style="padding:0 8px 8px 48px"><div style="font-size:.72rem;color:#5a8fd4;margin-bottom:5px">🥩 ความสุก${warn}</div><div class="qk-done-row">${opts}</div></td></tr>`;
        }
        const ctrl=qty===0
          ?`<button class="qk-add" onclick="QUICK.add('${item.id}')">+ เพิ่ม</button>`
          :`<div class="qk-qctrl">
              <button class="qk-qbtn" onclick="QUICK.remove('${item.id}')">−</button>
              <span class="qk-qn">${qty}</span>
              <button class="qk-qbtn" onclick="QUICK.add('${item.id}')">+</button>
            </div>`;
        const thSub=item.nameTh?`<div class="qk-nameth">${item.nameTh}</div>`:'';
        html+=`<tr>
          <td class="qk-td-emo">${item.image?`<img src="${item.image}" style="width:38px;height:38px;object-fit:cover;border-radius:7px">`:(item.emoji||'🍔')}</td>
          <td class="qk-td-info"><div class="qk-name">${item.name}</div>${thSub}</td>
          <td class="qk-price">฿${item.price}</td>
          <td class="qk-td-ctrl">${ctrl}</td>
        </tr>${doneRow}`;
      });
      html+=`</table></div>`;
    });
    G('qk-menu-area').innerHTML=html;
    this.updateCart();
  },

  setDone(id,val){
    if(!this.cart[id]){
      this._pendingDone=this._pendingDone||{};
      this._pendingDone[id]=val;
    } else {
      this.cart[id].doneness=val;
    }
    this.render();
  },

  add(id){
    const item=this.findItem(id);if(!item)return;
    const pending=(this._pendingDone||{})[id];
    const existing=(this.cart[id]||{}).doneness||'';
    if(item.doneness&&!existing&&!pending){
      // flash warning — no doneness selected yet, just show warning
      this.render(); return;
    }
    if(!this.cart[id])this.cart[id]={...item,qty:0,doneness:pending||''};
    else if(pending)this.cart[id].doneness=pending;
    this.cart[id].qty++;
    if(this._pendingDone)delete this._pendingDone[id];
    this.render();
  },

  remove(id){
    if(!this.cart[id])return;
    this.cart[id].qty--;
    if(this.cart[id].qty<=0)delete this.cart[id];
    this.render();
  },

  findItem(id){
    for(const arr of Object.values(this.menu)){
      const f=arr.find(i=>String(i.id)===String(id));
      if(f)return f;
    }return null;
  },

  updateCart(){
    const items=Object.values(this.cart);
    const qty=items.reduce((s,i)=>s+i.qty,0);
    const total=items.reduce((s,i)=>s+i.price*i.qty,0);
    G('qk-pill').textContent=`🛒 ${qty} · ฿${total.toLocaleString()}`;
    const area=G('qk-cart-area');
    if(!items.length){area.style.display='none';return;}
    area.style.display='block';
    G('qk-cart-rows').innerHTML=items.map(i=>{
