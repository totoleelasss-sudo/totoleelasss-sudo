const ORDER = {
  cart:{}, menu:null, orderId:null, sse:null, pollIv:null,
  init(){
    this.cart={}; this.menu=JSON.parse(JSON.stringify(DEFAULT_MENU));
    this.render(); this.updateCart();
    G('order-main').style.display='block';
    G('wait-box').style.display='none';
    G('ready-box').style.display='none';
    // Try Firebase in background — if it fails, DEFAULT_MENU already showing
    fbGet('/menu').then(m=>{
      if(m&&typeof m==='object'&&Object.keys(m).length>0){
        this.menu=m; this.render();
      }
    }).catch(()=>{});
  },
  find(id){for(const arr of Object.values(this.menu)){const f=arr.find(i=>String(i.id)===String(id));if(f)return f;}return null;},
  tab(cat,el){
    document.querySelectorAll('#pg-order .tab-btn').forEach(t=>t.classList.remove('on'));el.classList.add('on');
    ['burger','steak','drinks'].forEach(c=>G('grid-'+c).classList.toggle('off',c!==cat));
  },
  render(){
    const DONENESS=[
      {key:'rare',       th:'Rare — เลือดๆ',         en:'Rare'},
      {key:'medium-rare',th:'Medium Rare — ชมพูนุ่ม', en:'Medium Rare'},
      {key:'medium',     th:'Medium — กึ่งสุก',       en:'Medium'},
      {key:'medium-well',th:'Medium Well — เกือบสุก', en:'Medium Well'},
      {key:'well-done',  th:'Well Done — สุกทั้งชิ้น',en:'Well Done'},
    ];
    ['burger','steak','drinks'].forEach(cat=>{
      const el=G('grid-'+cat);if(!el)return;
      const items=(this.menu[cat]||[]);
      if(!items.length){el.innerHTML='<p style="padding:20px;color:#8a6040">ไม่มีเมนูในหมวดนี้</p>';return;}
      el.innerHTML=items.map(item=>{
        const a=item.available!==false;
        const cartItem=this.cart[item.id];
        const qty=cartItem?cartItem.qty:0;
        const selDone=cartItem?cartItem.doneness:'';
        const imgH=item.image?`<img src="${item.image}" alt="${item.name}" style="width:100%;height:140px;object-fit:cover;border-radius:9px;">`:`<div class="card-emo">${item.emoji||'🍔'}</div>`;
        const tags=(item.tag||'').split('·').map(t=>t.trim()).filter(Boolean);
        const tagH=tags.length?tags.map(t=>{const bs=t.toLowerCase().includes('best seller')||t.toLowerCase().includes('bestseller');return `<div class="card-tag${bs?' bs':''}">${bs?'⭐ ':''  }${t}</div>`;}).join(''):'';
        const thSub=item.nameTh?`<div class="card-name-th">${item.nameTh}</div>`:'';
        // Doneness selector (only for beef items)
        let doneH='';
        if(item.doneness&&a){
          const opts=DONENESS.map(d=>`<button class="d-opt${selDone===d.key?' sel':''}" data-d="${d.key}" onclick="ORDER.setDoneness('${item.id}','${d.key}')">${d.th}</button>`).join('');
          doneH=`<div class="doneness-wrap"><div class="doneness-lbl">🥩 ความสุกของเนื้อ</div><div class="doneness-opts">${opts}</div><div class="doneness-req" id="dreq-${item.id}">⚠ กรุณาเลือกระดับความสุกก่อน</div></div>`;
        }
        let ctrl='';
        if(a)ctrl=qty===0?`<button class="add-btn" onclick="ORDER.add('${item.id}')">+ เพิ่ม</button>`:`<div class="qty-ctrl"><button class="qty-btn" onclick="ORDER.remove('${item.id}')">−</button><span class="qty-n">${qty}</span><button class="qty-btn" onclick="ORDER.add('${item.id}')">+</button></div>`;
        return `<div class="mcard${a?'':' sold'}">${imgH}${tagH}<div class="card-name">${item.name}</div>${thSub}<div class="card-desc">${item.desc}</div>${doneH}${!a?'<div class="sold-lbl">⛔ หมดแล้ว</div>':''}<div class="card-foot"><div class="card-price">฿${item.price}</div>${ctrl}</div></div>`;
      }).join('');
    });
  },
  setDoneness(id,val){
    if(!this.cart[id]){
      // Pre-select before adding — store pending selection
      this._pendingDoneness=this._pendingDoneness||{};
      this._pendingDoneness[id]=val;
    } else {
      this.cart[id].doneness=val;
    }
    this.render();
  },
  add(id){
    const item=this.find(id);if(!item)return;
    // If item requires doneness, check selection
    if(item.doneness){
      const pending=(this._pendingDoneness||{})[id];
      const existing=this.cart[id]?this.cart[id].doneness:'';
      const chosen=existing||pending;
      if(!chosen){
        // Flash the warning
        const req=document.getElementById('dreq-'+id);
        if(req){req.classList.add('show');setTimeout(()=>req.classList.remove('show'),2500);}
        return;
      }
      if(!this.cart[id])this.cart[id]={...item,qty:0,doneness:chosen};
      this.cart[id].qty++;
      // clear pending
      if(this._pendingDoneness)delete this._pendingDoneness[id];
    } else {
      if(!this.cart[id])this.cart[id]={...item,qty:0};
      this.cart[id].qty++;
    }
    this.updateCart();this.render();
  },
  remove(id){if(!this.cart[id])return;this.cart[id].qty--;if(this.cart[id].qty<=0)delete this.cart[id];this.updateCart();this.render();},
  updateCart(){
    const items=Object.values(this.cart);
    const qty=items.reduce((s,i)=>s+i.qty,0),total=items.reduce((s,i)=>s+i.price*i.qty,0);
    G('cart-pill').textContent=`🛒 ${qty} · ฿${total.toLocaleString()}`;
    const box=G('cart-box');
    if(!items.length){box.style.display='none';return;}
    box.style.display='block';
    G('cart-rows').innerHTML=items.map(i=>{
      const dTag=i.doneness?`<span style="background:#3a1a00;color:#f0a830;border-radius:99px;padding:2px 9px;font-size:.78rem;margin-left:6px">${i.doneness.replace('-',' ')}</span>`:'';
      return `<div class="cart-row"><span style="font-size:1.3rem">${i.emoji||'🍔'}</span><span class="cart-name">${i.name}${dTag}</span><span class="cart-sub">x${i.qty}</span><span class="cart-price">฿${(i.price*i.qty).toLocaleString()}</span></div>`;
    }).join('');
    G('cart-total').textContent=`฿${total.toLocaleString()}`;
  },
  sumHtml(items,note){
    const total=items.reduce((s,i)=>s+i.price*i.qty,0);
    const rows=items.map(i=>{
      const dTag=i.doneness?`<span style="color:#f0a830;font-size:.8rem"> · ${i.doneness.replace(/-/g,' ')}</span>`:'';
      return `<div class="sumrow"><span>${i.emoji||'🍔'}</span><span style="flex:1">${i.name}${dTag}</span><span style="color:#8a6040">x${i.qty}</span><span style="color:#f0a830">฿${(i.price*i.qty).toLocaleString()}</span></div>`;
    }).join('');
    const noteH=note?`<div style="font-size:.8rem;color:#8a6040;margin-top:8px;padding-top:8px;border-top:1px solid #3a1a00">📝 ${note}</div>`:'';
    const totalH=`<div style="display:flex;justify-content:space-between;align-items:center;margin-top:12px;padding-top:12px;border-top:2px solid #c8801a"><span style="font-size:.85rem;color:#8a6040;text-transform:uppercase;letter-spacing:1px">ยอดรวม / Total</span><span style="font-family:'Playfair Display',serif;font-size:1.6rem;color:#f0a830;font-weight:700">฿${total.toLocaleString()}</span></div>`;
    return rows+noteH+totalH;
  },
  async place(){
    const tEl=G('table-inp'),table=tEl.value.trim(),note=G('note-inp').value.trim(),items=Object.values(this.cart);
    if(!table){tEl.classList.add('err');tEl.focus();setTimeout(()=>tEl.classList.remove('err'),2500);return;}
    if(!items.length){alert('กรุณาเลือกเมนูอย่างน้อย 1 รายการ');return;}
    const btn=G('send-btn');btn.disabled=true;btn.textContent='⏳ กำลังส่ง...';
    // Use Firebase server timestamp for accurate time (avoids phone clock drift)
    let serverTime=Date.now();
    try{
      const tr=await fetch(DB+'/.json?shallow=true');
      const th=tr.headers.get('Date');
      if(th)serverTime=new Date(th).getTime();
    }catch(e){}
    const oid=serverTime;this.orderId=oid;
    await fbSet(`/orders/${oid}`,{id:oid,table,note,items:items.map(i=>({id:i.id,name:i.name,emoji:i.emoji||'🍔',price:i.price,qty:i.qty,doneness:i.doneness||''})),status:'new',createdAt:oid});
    G('wait-id').textContent='#'+String(oid).slice(-4);
    G('wait-table').textContent=`🪑 ${table}`;
    G('wait-sum').innerHTML=this.sumHtml(items,note);
    G('order-main').style.display='none';G('wait-box').style.display='block';
    btn.disabled=false;btn.textContent='🚀 ส่งออเดอร์ไปครัว';
    this.listen(oid,items,note,table);
  },
  setStep(n){for(let i=1;i<=3;i++){G('sc'+i).className='step-c'+(i<n?' done':i===n?' on':'');G('sl'+i).className='step-l'+(i<n?' done':i===n?' on':'');if(i<3)G('sline'+i).className='step-line'+(i<n?' done':'');}},
  listen(oid,items,note,table){
    if(this.sse){try{this.sse.close();}catch(e){}}
    // Start SSE
    try{
      this.sse=new EventSource(`${DB}/orders/${oid}.json`);
      this.sse.addEventListener('put',e=>{
        try{
          const d=JSON.parse(e.data),o=d.data||d;
          if(!o||!o.status)return;
          if(o.status==='cooking')this.setStep(2);
          else if(o.status==='done'){this.setStep(3);try{this.sse.close();}catch(ex){}if(this.pollIv){clearInterval(this.pollIv);this.pollIv=null;}setTimeout(()=>this.showReady(oid,items,note,table),800);}
        }catch(ex){}
      });
      this.sse.onerror=()=>{try{this.sse.close();}catch(ex){}};
    }catch(e){}
    // Always run polling alongside SSE as backup (every 3s)
    if(this.pollIv)clearInterval(this.pollIv);
    this.pollIv=setInterval(async()=>{
      try{
        const o=await fbGet(`/orders/${oid}`);if(!o)return;
        if(o.status==='cooking')this.setStep(2);
        else if(o.status==='done'){clearInterval(this.pollIv);this.pollIv=null;this.setStep(3);setTimeout(()=>this.showReady(oid,items,note,table),800);}
      }catch(e){}
    },3000);
  },
  showReady(oid,items,note,table){
    // guard: don't show if already shown
    if(G('ready-box').style.display==='block')return;
    G('ready-id').textContent='#'+String(oid).slice(-4);
    G('ready-table').textContent=`🪑 ${table}`;
    G('ready-sum').innerHTML=this.sumHtml(items,note);
    G('wait-box').style.display='none';G('ready-box').style.display='block';
    document.title='🍔 อาหารพร้อมแล้ว!';
    // Play 3 times — immediately, then +3s, then +6s
    playReadyAlert();
    setTimeout(playReadyAlert,3000);
    setTimeout(playReadyAlert,6000);
  },
  reset(){
    if(this.sse){try{this.sse.close();}catch(e){}}
    if(this.pollIv){clearInterval(this.pollIv);this.pollIv=null;}
    this.sse=null;this.orderId=null;this.cart={};
    G('order-main').style.display='block';G('wait-box').style.display='none';G('ready-box').style.display='none';
    G('cart-box').style.display='none';G('cart-pill').textContent='🛒 0 · ฿0';
    G('table-inp').value='';G('note-inp').value='';document.title='Fleggfoods';this.setStep(1);this.render();
  }
};

/* ═══════════════════════════════════
   KITCHEN
═══════════════════════════════════ */
const KITCHEN = {
  orders:{}, audioOn:false, sse:null, clockIv:null, pollIv:null, sseOk:false, serverOffset:0,
  async syncServerTime(){
    try{
      const t0=Date.now();
      const r=await fetch(DB+'/.json?shallow=true');
      const t1=Date.now();
      const serverDate=r.headers.get('Date');
      if(serverDate){
        const serverMs=new Date(serverDate).getTime();
        // estimate: server time minus local midpoint of request
        this.serverOffset=serverMs-Math.round((t0+t1)/2);
      }
    }catch(e){}
  },
  init(){
    if(this.clockIv)clearInterval(this.clockIv);
    this.syncServerTime();
    // tick every second — updates clock AND kitchen timers live
    this.clockIv=setInterval(()=>{this.tick();this.renderTimers();},1000);
    this.tick();
    this.startSSE();
    if(this.pollIv)clearInterval(this.pollIv);
    this.pollIv=setInterval(()=>this.poll(),4000);
  },
  tick(){const n=new Date();G('k-clock').textContent=[n.getHours(),n.getMinutes(),n.getSeconds()].map(v=>String(v).padStart(2,'0')).join(':');},
  renderTimers(){
    // Fast path: just update timer spans in place, no full DOM rebuild
    Object.values(this.orders).forEach(o=>{
      if(o.status==='done')return;
      const el=document.getElementById('ktimer-'+o.id);
      if(!el)return;
      const e=this.elapsed(o.createdAt);
      el.textContent=`${e.m}:${e.s}`;
      el.className='ktimer '+this.timerClass(e.m);
      // update urg badge
      const ub=document.getElementById('kurg-'+o.id);
      if(ub){
        if(e.m>=20){ub.textContent='🔴 รอนานมาก!';ub.style.display='inline-block';ub.style.background='#e74c3c';}
        else if(e.m>=10){ub.textContent='⚠ รอนาน!';ub.style.display='inline-block';ub.style.background='#f1c40f';ub.style.color='#000';}
        else{ub.style.display='none';}
      }
    });
  },
  async poll(){
    // background poll to sync if SSE missed events
    try{
      const data=await fbGet('/orders');
      const fresh=data||{};
      const prevIds=new Set(Object.keys(this.orders));
      // detect new orders for sound alert
      Object.keys(fresh).forEach(id=>{
        if(!prevIds.has(id)&&this.audioOn)playSound('neworder',beep);
      });
      this.orders=fresh;
      this.render();
      if(!this.sseOk)this.setLive(true);
    }catch(e){}
  },
  enableAudio(){
    try{actx().resume();this.audioOn=true;playSound('neworder',beep);}catch(e){}
    const b=G('audio-btn');b.textContent='🔔 เสียงเปิดแล้ว';b.className='audio-btn on';b.onclick=null;
  },
  toast(msg,color='#2ecc71'){const t=G('k-toast');t.textContent=msg;t.style.background=color;t.style.color=color==='#e74c3c'?'#fff':'#000';t.classList.add('show');setTimeout(()=>t.classList.remove('show'),3000);},
  elapsed(ts){
    const now=Date.now()+(KITCHEN.serverOffset||0);
    const d=Math.max(0,now-ts);
    const totalSec=Math.floor(d/1000);
    return{
      m:Math.floor(totalSec/60),
      s:String(totalSec%60).padStart(2,'0'),
      totalSec
    };
  },
  timerClass(m){
    if(m>=20)return 't-red';
    if(m>=10)return 't-yellow';
    return 't-green';
  },
  render(){
    const all=Object.values(this.orders);
    const cols={new:[],cooking:[],done:[]};all.forEach(o=>{if(cols[o.status])cols[o.status].push(o);});
    const urg=all.filter(o=>o.status!=='done'&&this.elapsed(o.createdAt).m>=10).length;
    G('kst-new').textContent=cols.new.length;G('kst-cooking').textContent=cols.cooking.length;
    G('kst-done').textContent=cols.done.length;G('kst-urg').textContent=urg;
    G('kc-new').textContent=cols.new.length;G('kc-cooking').textContent=cols.cooking.length;G('kc-done').textContent=cols.done.length;
    this.renderCol('kb-new',cols.new,'new');
    this.renderCol('kb-cooking',cols.cooking,'cooking');
    this.renderCol('kb-done',cols.done,'done');
  },
  renderCol(elId,orders,status){
    const el=G(elId);
    if(!orders.length){const icons={new:'🍔',cooking:'👨‍🍳',done:'🎉'};el.innerHTML=`<div class="kempty"><div style="font-size:2rem;opacity:.4;margin-bottom:6px">${icons[status]}</div>ยังไม่มีออเดอร์</div>`;return;}
    el.innerHTML=orders.sort((a,b)=>a.createdAt-b.createdAt).map(o=>{
      const e=this.elapsed(o.createdAt);
      const tc=status==='done'?'t-green':this.timerClass(e.m);
      const tot=o.items.reduce((s,i)=>s+i.price*i.qty,0);
      const id='#'+String(o.id).slice(-4);
      const urgShow=status!=='done'&&e.m>=10;
      const urgColor=e.m>=20?'#e74c3c':'#f1c40f';
      const urgText=e.m>=20?'🔴 รอนานมาก!':'⚠ รอนาน!';
      const urgTextColor=e.m>=20?'#fff':'#000';
      const itemsH=o.items.map(i=>{
        const dTag=i.doneness?`<span style="background:#3a1a00;color:#f5a623;border-radius:99px;padding:1px 8px;font-size:.68rem;margin-left:5px">${i.doneness.replace(/-/g,' ')}</span>`:'';
        return `<div class="kitem"><div class="kitem-emo">${i.emoji}</div><div style="flex:1"><div class="kitem-name">${i.name}${dTag}</div>${o.note?`<div class="kitem-note">📝 ${o.note}</div>`:''}</div><div class="kitem-qty">x${i.qty}</div></div>`;
      }).join('');
      let acts='';
      if(status==='new')acts=`<button class="kbtn kbtn-start" onclick="KITCHEN.move(${o.id},'cooking')">🔥 เริ่มทำ</button><button class="kbtn kbtn-cancel" onclick="KITCHEN.move(${o.id},'remove')">✕</button>`;
      else if(status==='cooking')acts=`<button class="kbtn kbtn-done" onclick="KITCHEN.move(${o.id},'done')">✅ เสร็จ — แจ้งลูกค้า</button><button class="kbtn kbtn-cancel" onclick="KITCHEN.move(${o.id},'remove')">✕</button>`;
      else acts=`<button class="kbtn kbtn-clear" onclick="KITCHEN.move(${o.id},'remove')">🗑 ลบออก</button>`;
      return `<div class="kcard${urgShow&&e.m>=20?' urg':''}">
        <div class="kcard-top">
          <div><div class="kcard-id">${id}</div><div class="kcard-table">🪑 ${o.table}</div></div>
          <div style="text-align:right">
            <div id="ktimer-${o.id}" class="ktimer ${tc}">${e.m}:${e.s}</div>
            <div id="kurg-${o.id}" class="urg-tag" style="background:${urgColor};color:${urgTextColor};display:${urgShow?'inline-block':'none'}">${urgText}</div>
          </div>
        </div>
        <div class="kitems">${itemsH}</div>
        <div class="kactions">${acts}</div>
        <div class="ktotal">Total <span>฿${tot.toLocaleString()}</span></div>
      </div>`;
    }).join('');
  },
  async move(id,status){
    if(status==='remove'){await fbDel(`/orders/${id}`);delete this.orders[id];}
    else{await fbPatch(`/orders/${id}`,{status});if(this.orders[id])this.orders[id].status=status;if(status==='done')this.toast(`✅ แจ้งลูกค้า #${String(id).slice(-4)} แล้ว!`);}
    this.render();
  },
  async clearDone(){for(const o of Object.values(this.orders).filter(o=>o.status==='done')){await fbDel(`/orders/${o.id}`);delete this.orders[o.id];}this.render();},
  setLive(on){
    this.sseOk=on;
    G('ldot').className='ldot'+(on?'':' off');
    const l=G('llbl');l.textContent=on?'LIVE':'POLLING...';l.className='live-lbl'+(on?'':' off');
  },
  startSSE(){
    if(this.sse){try{this.sse.close();}catch(e){}}
    try{
      this.sse=new EventSource(`${DB}/orders.json`);
      this.sse.addEventListener('put',e=>{
        try{
          const {path,data}=JSON.parse(e.data);
          const prev=new Set(Object.keys(this.orders));
          if(path==='/'){
            this.orders=data||{};
            if(prev.size>0)Object.keys(this.orders).forEach(id=>{if(!prev.has(id)&&this.audioOn)playSound('neworder',beep);});
          } else {
            const id=path.replace('/','');
            if(data===null)delete this.orders[id];
            else{const isNew=!this.orders[id];this.orders[id]=data;if(isNew&&this.audioOn)playSound('neworder',beep);}
          }
          this.render();this.setLive(true);
        }catch(ex){}
      });
      // on error: mark offline, try reconnect in 5s (polling keeps running in background)
      this.sse.onerror=()=>{
        this.setLive(false);
        try{this.sse.close();}catch(e){}
        setTimeout(()=>this.startSSE(),5000);
      };
    }catch(e){this.setLive(false);}
  }
};

