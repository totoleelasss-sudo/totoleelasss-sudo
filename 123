═══════════════════════════════════ */
let _actx=null;
function actx(){if(!_actx)_actx=new(window.AudioContext||window.webkitAudioContext)();return _actx;}
function beep(){try{const c=actx();c.resume();[[880,0,.12],[660,.15,.12],[880,.3,.18]].forEach(([f,s,d])=>{const o=c.createOscillator(),g=c.createGain();o.connect(g);g.connect(c.destination);o.frequency.value=f;o.type='sine';g.gain.setValueAtTime(0,c.currentTime+s);g.gain.linearRampToValueAtTime(.5,c.currentTime+s+.01);g.gain.linearRampToValueAtTime(0,c.currentTime+s+d);o.start(c.currentTime+s);o.stop(c.currentTime+s+d+.05);});}catch(e){}}
function melody(){
  try{
    const c=actx();c.resume();
    // Louder, more prominent ready chime
    [[523,0,.2],[659,.22,.2],[784,.44,.2],[1047,.66,.5],[784,.88,.15],[1047,1.05,.6]].forEach(([f,s,d])=>{
      const o=c.createOscillator(),g=c.createGain();
      o.connect(g);g.connect(c.destination);
      o.frequency.value=f;o.type='sine';
      g.gain.setValueAtTime(0,c.currentTime+s);
      g.gain.linearRampToValueAtTime(.85,c.currentTime+s+.02);
      g.gain.linearRampToValueAtTime(0,c.currentTime+s+d);
      o.start(c.currentTime+s);o.stop(c.currentTime+s+d+.05);
    });
  }catch(e){}
}
function playSound(key,fallback){
  const d=localStorage.getItem('flegg_sound_'+key);
  if(d){try{const a=new Audio(d);a.volume=1.0;a.play().catch(()=>fallback());}catch(e){fallback();}}
  else fallback();
}
function playReadyAlert(){
  // vibrate on mobile if supported
  if(navigator.vibrate)navigator.vibrate([300,100,300,100,500]);
  playSound('ready',melody);
}
document.addEventListener('click',()=>{try{actx().resume();}catch(e){}},{once:true});

